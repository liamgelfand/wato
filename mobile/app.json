{
  "expo": {
    "name": "Wato",
    "slug": "wato",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "wato",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#6366f1"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wato.app"
    },
    "android": {
      "package": "com.wato.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset",
      "expo-font"
    ],
    "extra": {
      "apiUrl": "http://localhost:3000"
    }
  }
}
